# ============================================================
# REQUIRED: At least one LLM provider must be set.
# The system auto-selects based on what's available.
# ============================================================
DEEPSEEK_API_KEY=          # via OpenRouter (https://openrouter.ai) — primary reasoning model
GROQ_API_KEY=              # https://console.groq.com — fast inference, free tier
OPENAI_API_KEY=            # https://platform.openai.com
ANTHROPIC_API_KEY=         # https://console.anthropic.com
GEMINI_API_KEY=            # https://aistudio.google.com — used as fallback

# ============================================================
# REQUIRED: At least one search provider must be set.
# ============================================================
TAVILY_API_KEY=            # https://tavily.com — best quality, recommended
SEARCHAPI_API_KEY=         # https://www.searchapi.io — Google proxy fallback

# ============================================================
# OPTIONAL: Observability & persistence (safe to leave empty)
# ============================================================
LANGSMITH_API_KEY=         # https://smith.langchain.com — trace collection

# Vector DB — uses in-memory by default; set only for Qdrant Cloud
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Postgres/Supabase — session persistence; optional, degrades gracefully
SUPABASE_URL=
SUPABASE_KEY=

# ============================================================
# OPTIONAL: Advanced model overrides (leave empty to use defaults)
# ============================================================
MODEL_GROQ_QWEN32B=qwen/qwen3-32b
MODEL_GROQ_LLAMA_SCOUT=meta-llama/llama-4-scout-17b-16e-instruct
MODEL_GROQ_KIMI_K2=moonshotai/kimi-k2-instruct

# ============================================================
# OPTIONAL: Runtime tuning (defaults shown)
# ============================================================
USE_MOCK_LLM=false
CHECKPOINT_DB_PATH=data/checkpoints.sqlite
PLANNER_SEARCH_RESULTS=3
PLANNER_CONTEXT_SNIPPETS=3
SEARCH_PROVIDER_ORDER=tavily,playwright,searchapiio,duckduckgo
SEARCH_QUERY_SUFFIX=
SEARCH_ALLOW_FINAL_DUCKDUCKGO=true
SEARCH_PLAYWRIGHT_TIMEOUT_MS=30000
SEARCH_ALLOW_WIKIPEDIA_FALLBACK=true
HITL_DEFER_PATTERNS=\bno\s+opinion\b,\bno\s+preference\b,\bdo\s+whatever\b,\bdo\s+what(?:ever)?\s+you\s+think\b,\byou\s+decide\b,\byour\s+call\b,\bi\s+trust\s+you\b,\bup\s+to\s+you\b,\bno\s+strong\s+view\b

# Provider routing policy (auto-selected by budget_mode)
PROVIDER_ORDER_AUTO_HIGH=anthropic,openai,groq,together,gemini
PROVIDER_ORDER_AUTO_BALANCED=groq,anthropic,openai,together,gemini
PROVIDER_ORDER_AUTO_LOW=groq,gemini,together,openai,anthropic
PROVIDER_ORDER_MIXED_HIGH=anthropic,openai,groq,together,gemini
PROVIDER_ORDER_MIXED_BALANCED=groq,anthropic,openai,together,gemini

# Lane source hints (restrict search to authoritative domains per lane)
LANE_HINTS_GROQ_FAST=latest,site:news.google.com
LANE_HINTS_GROQ_DEEP=site:reuters.com,site:arxiv.org,site:sec.gov
LANE_HINTS_TOGETHER=site:wikipedia.org,site:britannica.com
LANE_HINTS_GEMINI=latest,site:google.com
LANE_HINTS_OPENAI=site:openai.com,site:github.com
LANE_HINTS_ANTHROPIC=site:anthropic.com,site:github.com

# u-mem cross-session memory (optional — only if u-mem is installed)
UMEM_SRC_PATHS=
UMEM_BOOTSTRAP_LIMIT=8
UMEM_BOOTSTRAP_MIN_IMPORTANCE=2
UMEM_BOOTSTRAP_BUDGET_TOKENS=1000
UMEM_SEARCH_MIN_IMPORTANCE=2
UMEM_SAVE_MAX_CHARS=3000
UMEM_DEFAULT_TAG=research-swarm
